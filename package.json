{
  "name": "dsa-suite-platform",
  "private": true,
  "packageManager": "pnpm@10.6.2",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write .",
    "db:generate": "pnpm --filter @apps/api prisma:generate",
    "db:migrate": "pnpm --filter @apps/api prisma:migrate",
    "db:seed": "pnpm --filter @apps/api prisma:seed"
  },
  "devDependencies": {
    "prettier": "^3.5.3",
    "turbo": "^2.4.4",
    "@eslint/js": "^9.22.0",
    "eslint": "^9.22.0",
    "globals": "^16.0.0",
    "typescript-eslint": "^8.26.0"
  }
}
