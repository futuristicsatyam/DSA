generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER
  ADMIN
}

enum OtpType {
  EMAIL_VERIFY
  PHONE_VERIFY
  RESET_PASSWORD
}

enum CategoryType {
  DSA
  CP
  GATE
}

enum Difficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum BookmarkType {
  TOPIC
  EDITORIAL
  PROBLEM
}

enum Verdict {
  PENDING
  ACCEPTED
  WRONG_ANSWER
  TIME_LIMIT_EXCEEDED
  RUNTIME_ERROR
  COMPILATION_ERROR
  MEMORY_LIMIT_EXCEEDED
}

model User {
  id              String          @id @default(cuid())
  name            String
  email           String?         @unique
  phone           String?         @unique
  passwordHash    String
  emailVerified   Boolean         @default(false)
  phoneVerified   Boolean         @default(false)
  role            Role            @default(USER)
  refreshTokenHash String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  otps            Otp[]
  bookmarks       Bookmark[]
  progress        UserProgress[]
  recentlyViewed  RecentlyViewed[]
  submissions     Submission[]

  @@index([email])
  @@index([phone])
}

model Otp {
  id         String   @id @default(cuid())
  userId     String?
  target     String
  type       OtpType
  code       String
  expiresAt  DateTime
  verified   Boolean  @default(false)
  attempts   Int      @default(0)
  createdAt  DateTime @default(now())

  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([target, type])
}

model Subject {
  id            String       @id @default(cuid())
  name          String
  slug          String       @unique
  description   String
  categoryType  CategoryType
  parentId      String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  parent        Subject?     @relation("SubjectHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children      Subject[]    @relation("SubjectHierarchy")
  topics        Topic[]

  @@index([categoryType])
}

model Topic {
  id                String         @id @default(cuid())
  subjectId         String
  title             String
  slug              String         @unique
  shortDescription  String
  difficulty        Difficulty?
  orderIndex        Int?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  subject           Subject        @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  editorials        Editorial[]
  bookmarks         Bookmark[]
  progress          UserProgress[]
  recentlyViewed    RecentlyViewed[]

  @@index([subjectId])
}

model Editorial {
  id               String      @id @default(cuid())
  topicId          String
  title            String
  slug             String      @unique
  summary          String
  markdownContent  String
  tags             String[]
  estimatedMinutes Int?
  published        Boolean     @default(false)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  topic            Topic       @relation(fields: [topicId], references: [id], onDelete: Cascade)
  bookmarks        Bookmark[]

  @@index([topicId])
  @@index([published])
}

model Bookmark {
  id          String       @id @default(cuid())
  userId      String
  type        BookmarkType
  topicId     String?
  editorialId String?
  problemId   String?
  createdAt   DateTime     @default(now())

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic       Topic?       @relation(fields: [topicId], references: [id], onDelete: Cascade)
  editorial   Editorial?   @relation(fields: [editorialId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@unique([userId, topicId])
  @@unique([userId, editorialId])
}

model UserProgress {
  id              String     @id @default(cuid())
  userId          String
  topicId         String
  completed       Boolean    @default(false)
  progressPercent Int        @default(0)
  lastViewedAt    DateTime   @default(now())
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic           Topic      @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([userId, topicId])
  @@index([userId, completed])
}

model RecentlyViewed {
  id        String   @id @default(cuid())
  userId    String
  topicId   String
  viewedAt  DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic     Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@index([userId, viewedAt])
}

model Problem {
  id                  String       @id @default(cuid())
  title               String
  slug                String       @unique
  statementMarkdown   String
  inputFormat         String
  outputFormat        String
  constraintsMarkdown String
  sampleCases         Json
  difficulty          Difficulty?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  submissions         Submission[]
}

model Submission {
  id         String    @id @default(cuid())
  userId     String
  problemId  String
  language   String
  sourceCode String
  verdict    Verdict   @default(PENDING)
  runtimeMs  Int?
  memoryKb   Int?
  createdAt  DateTime  @default(now())

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem    Problem   @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@index([userId, problemId])
}
